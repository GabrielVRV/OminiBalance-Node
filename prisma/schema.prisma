generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Tabela de usuários — equivalente à classe Usuario do seu models.py
model Usuario {
  id    Int     @id @default(autoincrement())
  nome  String
  email String  @unique
  senha String
  ativo Boolean @default(true)
  admin Boolean @default(false)

  // Relacionamentos — um usuário tem muitas contas, categorias, etc
  contas     Conta[]
  categorias Categoria[]
  terceiros  Terceiro[]
}

// Tabela de contas bancárias
model Conta {
  id         Int    @id @default(autoincrement())
  nome       String
  tipo       String
  balanco    Float  @default(0.0)

  // Chave estrangeira — toda conta pertence a um usuário
  usuario_id Int
  usuario    Usuario @relation(fields: [usuario_id], references: [id])
}

// Tabela de categorias de transação
model Categoria {
  id   Int    @id @default(autoincrement())
  nome String
  tipo String

  usuario_id Int
  usuario    Usuario @relation(fields: [usuario_id], references: [id])
}

// Tabela de terceiros (pessoas/empresas envolvidas em transações)
model Terceiro {
  id   Int    @id @default(autoincrement())
  nome String

  usuario_id Int
  usuario    Usuario @relation(fields: [usuario_id], references: [id])
}